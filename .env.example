# Adminlösenord (server only — lägg INTE i NEXT_PUBLIC_*)
ADMIN_PASSWORD="change-me"
# Lock picks after first kickoff (CEST)
PREDICTION_LOCK_AT="2026-06-11T21:00:00+02:00"

# Firebase (client — no auth, display name only)
NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_DATABASE_URL="https://your-project-id-default-rtdb.firebaseio.com"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789:web:abc123"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"

# Server (API routes) — krävs för att gå med i tipset, topplista m.m.
# Hela JSON på en rad (från Firebase → Service accounts → Generate new private key):
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# Alternativ för Vercel (samma JSON, base64-kodad):
# FIREBASE_SERVICE_ACCOUNT_BASE64=
